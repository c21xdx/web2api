            "type": "string",
            "description": "The mode to switch to. Allowed values: 'plan'."
          },
          "explanation": {
            "type": "string",
            "description": "Optional explanation for why the mode switch is requested. This helps the user understand why you're switching modes."
          }
        },
        "required": [
          "target_mode_id"
        ]
      }
    }
