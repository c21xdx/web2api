            "description": "An optional file path to access a .pen file.",
            "type": "string"
          },
          "maxDepth": {
            "description": "Limit how deep to descend in the node tree. If omitted, the search is limited to the node and its direct children. When maxDepth is reached, omitted children are replaced with \"...\". Unlimited depth can result in a lot of data, prefer specifying a maxDepth.",
            "type": "number"
          },
          "parentId": {
            "description": "Only return the layout rectangles in this node's subtree. If omitted returns the layout of the whole document.",
            "type": "string"
          },
          "problemsOnly": {
            "description": "Only return nodes that have some kind of problem with their layout, e.g. they are clipped by their parents. If omitted, the value is `false`.",
